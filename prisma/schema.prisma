generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExperienceLevel {
  NOVICE
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ELITE
}

enum BlockStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum WeekStatus {
  PLANNED
  COMPLETED
  SKIPPED
}

model Activity {
  id                 String   @id
  name               String?
  date               DateTime
  distanceKm         Float
  durationSecs       Int
  avgPaceSecKm       Int
  avgHeartRate       Int?
  maxHeartRate       Int?
  calories           Int?
  activityType       String
  syncedAt           DateTime @default(now())
  elapsedTimeSecs    Int?
  elevationGainM     Float?
  startLat           Float?
  startLon           Float?
  manual             Boolean  @default(false)
  splits             Json?
  temperatureC       Float?
  humidityPct        Float?
  weatherFetchedAt   DateTime?
  // 0–10 run quality score (calculateRunRating + sync/backfill only)
  rating             Float?
  // JSON: RunRatingResult (pace, effort, distance, elevation, conditions); null before backfill
  ratingBreakdown    Json?
  // Pace-zone type from classifyRunByPaceZones; kept in sync with rating
  classifiedRunType  String?
  // User-confirmed override; null = unreviewed
  confirmedRunType   String?
  // ID of the matched planned session
  linkedSessionId    String?
  // Whether the user has confirmed this run's classification
  isConfirmed        Boolean  @default(false)
  // Subjective feedback for Novice/Adaptive logic
  sRPE               Int?
  painLevel          Int?
  feltSharpPain      Boolean  @default(false)
  // JSON array of Strava per-km splits_metric entries.
  splitsJson         Json?
  // Human-readable explanation of classification confidence/method.
  classificationMethod String?
}

model Profile {
  id                Int       @id @default(1)
  name              String    @default("Cameron")
  dateOfBirth       DateTime
  heightCm          Int       @default(174)
  stravaConnected   Boolean   @default(false)
  stravaToken       String?
  stravaRefresh     String?
  stravaTokenExpiry DateTime?
  lastRefreshedAt   DateTime?
  timezone          String    @default("Australia/Brisbane")
}

model UserSettings {
  id                    Int       @id @default(1)
  planStartDate         DateTime?
  currentWeekOverride   Int?
  phaseOverride         String?
  experienceLevel       ExperienceLevel?
  goalRace              String?
  planLengthWeeks       Int?
  targetFinishTime      Int?
  trainingDays          String?
  longRunDay            String?
  maxHR                 Int       @default(198)
  startingTempoPaceSec  Int       @default(390)
  currentVdot           Int       @default(33)
  vdotRaceDistance      String?
  vdotRaceMinutes       Int?
  vdotRaceSeconds       Int?
  targetHMTimeSec       Int       @default(6900)
  raceName              String?
  raceDate              DateTime?
  distTargetEasyM       Int       @default(7000)
  distTargetTempoM      Int       @default(10000)
  distTargetIntervalM   Int       @default(8000)
  distTargetLongM       Int       @default(18000)
  age                   Int?
  gender                String?
  weightKg              Float?
  runningExperience     String?
  easyPaceOffsetSec     Int       @default(0)
  tempoPaceOffsetSec    Int       @default(0)
  intervalPaceOffsetSec Int       @default(0)
  longPaceOffsetSec     Int       @default(0)
  easyPaceMinSec        Int       @default(390)
  easyPaceMaxSec        Int       @default(450)
  tempoPaceMinSec       Int       @default(330)
  tempoPaceMaxSec       Int       @default(390)
  intervalPaceMinSec    Int       @default(300)
  intervalPaceMaxSec    Int       @default(330)
  longPaceMinSec        Int       @default(390)
  longPaceMaxSec        Int       @default(450)
  firstName             String?
  nickname              String?
  lastCutbackInsertedWeek Int?
  lastEstimatedVdot     Int?
  lastVdotCheckDate     DateTime?
  lastAdaptationDate    DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model PlayerRating {
  id               String   @id @default(cuid())
  updatedAt        DateTime @updatedAt
  overall          Float
  speed            Float
  endurance        Float
  resilience       Float    @default(1)
  hrEfficiency     Float
  toughness        Float
  prevOverall      Float
  prevSpeed        Float
  prevEndurance    Float
  prevResilience   Float    @default(1)
  prevHrEfficiency Float
  prevToughness    Float
}

model PlanInterruption {
  id               String    @id @default(cuid())
  reason           String
  type             String
  startDate        DateTime
  endDate          DateTime?
  weeklyKmEstimate Float?
  notes            String?
  weeksAffected    Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model GeneratedPlan {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  planJson    String
  configJson  String
  lockedWeeks String?

  noviceSessionCheckins   NoviceSessionCheckin[]
  noviceWeeklyEvaluations NoviceWeeklyEvaluation[]
  novicePlanMutations     NovicePlanMutation[]
  noviceHandoffData       NoviceHandoffData?
}

model NoviceSessionCheckin {
  id                      String   @id @default(cuid())
  sessionId               String
  planId                  String
  weekNumber              Int
  sessionType             String
  plannedDistanceKm       Float
  plannedDurationMin      Float
  stravaActivityId        String?
  actualDistanceKm        Float?
  actualDurationMin       Float?
  averagePaceSecPerKm     Float?
  averageHeartRate        Float?
  maxHeartRate            Float?
  perceivedEffortFromHr   Float?
  completed               Boolean
  userRpe                 Int
  skippedReason           String?
  distanceCompletionRatio Float?
  effortScore             Float?
  createdAt               DateTime @default(now())

  plan GeneratedPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, weekNumber])
}

model NoviceWeeklyEvaluation {
  id                       String   @id @default(cuid())
  userId                   String
  planId                   String
  weekNumber               Int
  totalSessionsPlanned     Int
  totalSessionsCompleted   Int
  completionRate           Float
  totalPlannedKm           Float
  totalActualKm            Float?
  volumeCompletionRatio    Float?
  averageUserRpe           Float
  averageEffortScore       Float?
  sessionsMissed           Int
  missedReasons            String[]
  hasInjuryFlag            Boolean
  hasIllnessFlag           Boolean
  adaptiveDecision         String
  decisionReason           String
  evaluatedAt              DateTime @default(now())

  plan GeneratedPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, weekNumber])
}

model NovicePlanMutation {
  id                       String   @id @default(cuid())
  planId                   String
  triggeredByEvaluation    String
  weekNumber               Int
  mutationType             String
  originalWeekData         Json
  mutatedWeekData          Json
  createdAt                DateTime @default(now())

  plan GeneratedPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

model NoviceHandoffData {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  planId                   String   @unique
  completedGoal            String
  programWeeks             Int
  totalSessionsCompleted   Int
  totalKmCovered           Float
  estimatedPaceSecPerKm    Float?
  peakWeeklyKm             Float
  averageWeeklyRpe         Float
  suggestedNextLevel       String
  suggestedNextGoal        String
  graduatedAt              DateTime @default(now())

  plan GeneratedPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model PlanAdaptation {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  weekNumber Int
  type       String
  reason     String
  changes    String
  dismissed  Boolean  @default(false)
}

model TrainingBlock {
  id             String            @id @default(cuid())
  userId         Int               @default(1)
  status         BlockStatus       @default(ACTIVE)
  startingVdot   Float
  startingLevel  ExperienceLevel
  goalDistanceKm Float
  targetDate     DateTime
  targetTimeSecs Int?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  weeks          TrainingWeekRecord[]
}

model TrainingWeekRecord {
  id              String         @id @default(cuid())
  trainingBlockId String
  trainingBlock   TrainingBlock @relation(fields: [trainingBlockId], references: [id])
  weekNumber      Int
  isCutback       Boolean
  status          WeekStatus     @default(PLANNED)
  phase           String
  sessionsJson    Json
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([trainingBlockId, weekNumber])
}
